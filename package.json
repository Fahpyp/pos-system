{
  "name": "pos-system",
  "version": "1.0.0",
  "private": true,
  "main": "main.js",
  "description": "POS System Desktop App",
  "author": "POS-TEST",
  "scripts": {
    "dev": "concurrently \"next dev\" \"electron .\"",
    "build": "next build && node copy-static.js",
    "dist": "electron-builder",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-select": "^2.1.1",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-toast": "^1.2.1",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "electron-updater": "^6.8.3",
    "jose": "^5.6.3",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.400.0",
    "mysql2": "^3.9.7",
    "next": "14.2.5",
    "react": "^18",
    "react-dom": "^18",
    "recharts": "^2.12.7",
    "tailwind-merge": "^2.6.1",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10",
    "concurrently": "^9.2.1",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.5",
    "postcss": "^8",
    "tailwindcss": "^3.4.4",
    "typescript": "^5"
  },
  "build": {
    "appId": "com.pos.system",
    "productName": "POS-System",
    "asar": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      {
        "from": ".next",
        "to": ".next"
      },
      {
        "from": "public",
        "to": "public"
      },
      ".env.production",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    }
  }
}
